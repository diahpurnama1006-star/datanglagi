<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="640.0" prefWidth="360.0" spacing="15" style="-fx-background-color:#F8F5F2;" xmlns="http://javafx.com/javafx/25.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.datanglagi.controller.CalenderController">

<VBox prefHeight="90" spacing="2" style="-fx-background-color:#6E1418;">

    <padding>
        <Insets left="20" top="20" />
    </padding>

    <children>

        <Label style="-fx-text-fill:white;                       -fx-font-size:24;                       -fx-font-weight:bold;" text="Kalender DatangLagi" />

        <Label style="-fx-text-fill:#E5CACA;                       -fx-font-size:12;" text="Lacak siklus dan catatan harian" />

    </children>

</VBox>

    <!-- BULAN -->
<HBox alignment="CENTER" spacing="55">

    <children>

        <Button onAction="#prevMonth" prefHeight="35" prefWidth="35" style="-fx-background-radius:20;                        -fx-background-color:#F3EEEE;" text="‹" />

        <Label fx:id="monthLabel" style="-fx-font-size:18;                       -fx-font-weight:bold;" />

        <Button onAction="#nextMonth" prefHeight="35" prefWidth="35" style="-fx-background-radius:20;                        -fx-background-color:#F3EEEE;" text="›" />

    </children>

</HBox>

<HBox spacing="23">

    <padding>
        <Insets left="20" />
    </padding>

    <children>
        <Label text="SEN" />
        <Label text="SEL" />
        <Label text="RAB" />
        <Label text="KAM" />
        <Label text="JUM" />
        <Label text="SAB" />
        <Label text="MIN" />
    </children>

</HBox>

    <!-- HARI -->
<GridPane fx:id="calendarGrid" hgap="8" prefWidth="320" vgap="12">

    <padding>
        <Insets left="20" right="20" />
    </padding>

    <columnConstraints>
        <ColumnConstraints percentWidth="14.28" />
        <ColumnConstraints percentWidth="14.28" />
        <ColumnConstraints percentWidth="14.28" />
        <ColumnConstraints percentWidth="14.28" />
        <ColumnConstraints percentWidth="14.28" />
        <ColumnConstraints percentWidth="14.28" />
        <ColumnConstraints percentWidth="14.28" />
    </columnConstraints>

    <rowConstraints>
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
    </rowConstraints>

</GridPane>
   <Pane prefHeight="49.0" prefWidth="318.0">
      <children>
         <ToggleButton fx:id="btnmulai" layoutX="65.0" layoutY="12.0" mnemonicParsing="false" text="Mulai Haid" />
         <ToggleButton fx:id="btnakhir" layoutX="200.0" layoutY="12.0" mnemonicParsing="false" text="Akhir Haid" />
      </children>
   </Pane>

</VBox>
