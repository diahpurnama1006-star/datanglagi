<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="640.0" prefWidth="360.0" style="-fx-background-color: linear-gradient(to right, #5A0F14, #7A1A1A);" xmlns="http://javafx.com/javafx/25.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.datanglagi.controller.HomepageController">
    
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="93.0" prefWidth="360.0" spacing="15.0" style="-fx-padding: 40 20 20 20; -fx-background-color: #6E1418;">
            <VBox alignment="CENTER_LEFT">
                <Label text="Hallo" textFill="WHITE"><font><Font name="System Bold" size="20.0" /></font></Label>
            <Label fx:id="lblUsername" text="Username" textFill="WHITE">
               <font>
                  <Font name="Poppins SemiBold" size="14.0" />
               </font>
            </Label>
                <Label fx:id="lblHari" style="-fx-opacity: 0.8;" text="Hari" textFill="WHITE" />
            </VBox>
        </HBox>
    </top>

    <center>
        <VBox prefHeight="566.0" prefWidth="360.0" spacing="18" style="-fx-background-color: white; -fx-background-radius: 25 25 0 0; -fx-padding: 25;" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #F9F7F5; -fx-background-radius: 15; -fx-padding: 15;">
                <ImageView fitHeight="70" fitWidth="70">
               <image>
                  <Image url="@../images/moon.png" />
               </image>
            </ImageView>
                <VBox alignment="CENTER_LEFT">
                    <Label style="-fx-text-fill: #555;" text="Prediksi haid berikutnya" />
                    <Label fx:id="lblHariKe" style="-fx-font-weight: bold; -fx-font-size: 20px;" text="Hari ke-" />
                    <Label fx:id="lblTanggalHaidNext" style="-fx-font-weight: bold;" text="Tanggal Haid" />
                </VBox>
            </HBox>

                     <Label style="-fx-font-weight: bold;" text="Perubahan mood hari ini" />
            <HBox alignment="CENTER" spacing="20">
                <VBox alignment="CENTER" spacing="5">
               <ImageView fx:id="imgMood" fitHeight="35" fitWidth="35">
                  <image>
                     <Image url="@../images/face-angry-regular.png" />
                  </image>
               </ImageView>
               <Label fx:id="lblMarah" text="marah" />
            </VBox>
                <VBox alignment="CENTER" spacing="5">
               <ImageView fitHeight="35" fitWidth="35">
                  <image>
                     <Image url="@../images/face-frown-regular.png" />
                  </image>
               </ImageView>
               <Label fx:id="lblSedih" text="sedih" />
            </VBox>
                <VBox alignment="CENTER" spacing="5">
               <ImageView fitHeight="35" fitWidth="35">
                  <image>
                     <Image url="@../images/face-meh-regular.png" />
                  </image>
               </ImageView>
               <Label fx:id="lblBiasa" text="biasa" />
            </VBox>
                <VBox alignment="CENTER" spacing="5">
               <ImageView fitHeight="35" fitWidth="35">
                  <image>
                     <Image url="@../images/face-grin-beam-regular.png" />
                  </image>
               </ImageView>
               <Label fx:id="lblSenang" text="senang" />
            </VBox>
            </HBox>

            <Label style="-fx-font-weight: bold;" text="Ringkasan Siklus" />
            <VBox spacing="10">
                <HBox>
               <Label text="Panjang Siklus" />
               <Region HBox.hgrow="ALWAYS" />
               <Label fx:id="lblPanjangSiklusVal" style="-fx-font-weight: bold;" text="Panjang" />
            </HBox>
                <HBox>
               <Label text="Durasi Haid" />
               <Region HBox.hgrow="ALWAYS" />
               <Label fx:id="lblDurasiHaidVal" style="-fx-font-weight: bold;" text="Durasi" />
            </HBox>
                <HBox>
               <Label text="Hari Ovulasi" />
               <Region HBox.hgrow="ALWAYS" />
               <Label fx:id="lblOvulasiVal" style="-fx-font-weight: bold;" text="Ovulasi" />
            </HBox>
                <HBox>
               <Label text="Siklus Dicatat" />
               <Region HBox.hgrow="ALWAYS" />
               <Label fx:id="lblSiklusDicatatVal" style="-fx-font-weight: bold;" text="Siklus" />
            </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
