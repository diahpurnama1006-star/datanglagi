<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="640.0" prefWidth="360.0" style="-fx-background-color: linear-gradient(to right, #5A0F14, #7A1A1A);" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.datanglagi.controller.HomepageController">
    
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="93.0" prefWidth="360.0" spacing="15.0" style="-fx-padding: 40 20 20 20;">
            <VBox alignment="CENTER_LEFT">
                <Label fx:id="labelHaloUser" text="Hallo User" textFill="WHITE"><font><Font name="System Bold" size="20.0" /></font></Label>
                <Label fx:id="labelTanggalHariIni" style="-fx-opacity: 0.8;" text="Selasa, 26 Mei 2026" textFill="WHITE" />
            </VBox>
        </HBox>
    </top>

    <center>
        <VBox prefHeight="566.0" prefWidth="360.0" spacing="18" style="-fx-background-color: white; -fx-background-radius: 25 25 0 0; -fx-padding: 25;" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #F9F7F5; -fx-background-radius: 15; -fx-padding: 15;">
                <ImageView fitHeight="70" fitWidth="70">
               <image>
                  <Image url="@../images/moon.png" />
               </image>
            </ImageView>
                <VBox alignment="CENTER_LEFT">
                    <Label style="-fx-text-fill: #555;" text="Prediksi haid berikutnya" />
                    <Label fx:id="labelHariLagi" style="-fx-font-weight: bold; -fx-font-size: 20px;" text="8 hari lagi" />
                    <Label fx:id="labelTanggalPrediksi" style="-fx-font-weight: bold;" text="3 Juni 2026" />
                </VBox>
            </HBox>

                     <Label style="-fx-font-weight: bold;" text="Perubahan mood hari ini" />
            <HBox alignment="CENTER" spacing="20">
                <VBox alignment="CENTER" spacing="5">
               <ImageView fitHeight="35" fitWidth="35">
                  <image>
                     <Image url="@../images/face-angry-regular.png" />
                  </image>
               </ImageView>
               <Label text="marah" />
            </VBox>
                <VBox alignment="CENTER" spacing="5">
               <ImageView fitHeight="35" fitWidth="35">
                  <image>
                     <Image url="@../images/face-frown-regular.png" />
                  </image>
               </ImageView>
               <Label text="sedih" />
            </VBox>
                <VBox alignment="CENTER" spacing="5">
               <ImageView fitHeight="35" fitWidth="35">
                  <image>
                     <Image url="@../images/face-meh-regular.png" />
                  </image>
               </ImageView>
               <Label text="biasa" />
            </VBox>
                <VBox alignment="CENTER" spacing="5">
               <ImageView fitHeight="35" fitWidth="35">
                  <image>
                     <Image url="@../images/face-grin-beam-regular.png" />
                  </image>
               </ImageView>
               <Label text="senang" />
            </VBox>
            </HBox>

                     <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #FFF0F0; -fx-background-radius: 10; -fx-padding: 15;">
                <VBox HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-weight: bold;" text="Hubungan Pasangan" />
                    <Label style="-fx-font-size: 11px;" text="Beri tahu pasanganmu tentang keadaanmu" />
                </VBox>
                <Button style="-fx-background-color: #8B0000; -fx-text-fill: white; -fx-background-radius: 5;" text="Tambah" />
            </HBox>

            <Label style="-fx-font-weight: bold;" text="Ringkasan Siklus" />
            <VBox spacing="10">
                <HBox>
               <Label text="Panjang Siklus" />
               <Region HBox.hgrow="ALWAYS" />
               <Label fx:id="labelPanjangSiklus" style="-fx-font-weight: bold;" text="28 Hari" />
            </HBox>
                <HBox>
               <Label text="Durasi Haid" />
               <Region HBox.hgrow="ALWAYS" />
               <Label fx:id="labelDurasiHaid" style="-fx-font-weight: bold;" text="5 Hari" />
            </HBox>
                <HBox>
               <Label text="Hari Ovulasi" />
               <Region HBox.hgrow="ALWAYS" />
               <Label fx:id="labelHariOvulasi" style="-fx-font-weight: bold;" text="14" />
            </HBox>
                <HBox>
               <Label text="Siklus Dicatat" />
               <Region HBox.hgrow="ALWAYS" />
               <Label fx:id="labelSiklusDicatat" style="-fx-font-weight: bold;" text="3 Kali" />
            </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
